BOT_TOKEN=telegram_bot_token_from_botfather
DB_PATH=bot.db

OPENAI_API_KEY=openai_or_compatible_api_key

# Admin notifications chat/user.
ADMIN_CHAT_ID=123456789

# Explicit Telegram user IDs allowed to open /admin.
# Required when ENV=production.
ADMIN_IDS=123456789

# Optional feedback destination. Defaults to ADMIN_CHAT_ID when empty.
FEEDBACK_CHAT_ID=123456789

# Optional model overrides.
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_FREE=gpt-4o-mini
OPENAI_MODEL_PLUS=gpt-4o-mini
OPENAI_MODEL_PRO=gpt-4o-mini
OPENAI_MODEL_VIP=gpt-4o-mini

# Optional YooKassa settings for Plus payments.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://t.me/<bot_username>
YOOKASSA_RECEIPT_EMAIL=
YOOKASSA_TAX_SYSTEM_CODE=
YOOKASSA_VAT_CODE=1

# Optional clinic contacts JSON.
CLINIC_CONTACTS_JSON=

LOG_LEVEL=INFO
ERROR_LOG_PATH=errors.log

# Optional PWA login bridge. The same secret must be set in the PWA as TELEGRAM_AUTH_SECRET.
PWA_BASE_URL=https://temichevvet.ru
PWA_TELEGRAM_AUTH_SECRET=

# Optional closed RU Core API bridge.
# Telegram bot stays on NL and mirrors data changes to the RU Core API.
CORE_SYNC_ENABLED=0
CORE_API_URL=https://temichevvet.ru
CORE_API_TOKEN=
CORE_SYNC_INTERVAL_SECONDS=10
CORE_SYNC_BATCH_SIZE=100
CORE_PULL_ENABLED=0
CORE_PULL_INTERVAL_SECONDS=10
CORE_PULL_BATCH_SIZE=100

# development / production
ENV=development
